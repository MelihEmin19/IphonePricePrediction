@model IEnumerable<IphonePriceWeb.Data.Entities.Listing>
@{
    ViewData["Title"] = "İlan Yönetimi (CRUD)";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2><i class="bi bi-list-ul me-2"></i>İlan Yönetimi</h2>
        <a asp-action="CreateListing" class="btn btn-success">
            <i class="bi bi-plus-circle me-1"></i>Yeni İlan Ekle
        </a>
    </div>
    <p class="text-muted">CREATE, READ, UPDATE, DELETE işlemleri</p>
    
    <hr />

    <div class="card shadow">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Model</th>
                        <th>Fiyat</th>
                        <th>Durum</th>
                        <th>Kaynak</th>
                        <th>Aktif</th>
                        <th>Tarih</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Spec?.Model?.Name</td>
                                <td class="text-success fw-bold">₺@item.Price.ToString("N0")</td>
                                <td><span class="badge bg-info">@item.Condition</span></td>
                                <td>@item.Source</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Pasif</span>
                                    }
                                </td>
                                <td>@item.ScrapedAt.ToString("dd.MM.yyyy")</td>
                                <td>
                                    <a asp-action="EditListing" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="DeleteListing" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4">Veri bulunamadı.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

