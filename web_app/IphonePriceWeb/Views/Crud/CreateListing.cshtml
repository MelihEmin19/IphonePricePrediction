@model IphonePriceWeb.Data.Entities.Listing
@{
    ViewData["Title"] = "Yeni İlan Ekle";
    var specs = ViewBag.Specs as List<IphonePriceWeb.Data.Entities.Spec>;
}

<div class="container mt-4">
    <h2><i class="bi bi-plus-circle me-2"></i>Yeni İlan Ekle (CREATE)</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body">
                    <form asp-action="CreateListing" method="post">
                        <div class="mb-3">
                            <label class="form-label">Spec (Model + RAM + Storage)</label>
                            <select asp-for="SpecId" class="form-select" required>
                                <option value="">-- Seçin --</option>
                                @if (specs != null)
                                {
                                    @foreach (var spec in specs)
                                    {
                                        <option value="@spec.Id">
                                            @spec.Model?.Name - @spec.RamGb GB RAM - @spec.StorageGb GB
                                        </option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label">Fiyat (TL)</label>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" required />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Condition" class="form-label">Durum</label>
                            <select asp-for="Condition" class="form-select" required>
                                <option value="Mükemmel">Mükemmel</option>
                                <option value="Çok İyi">Çok İyi</option>
                                <option value="İyi">İyi</option>
                                <option value="Orta">Orta</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Source" class="form-label">Kaynak</label>
                            <input asp-for="Source" class="form-control" placeholder="N11, EasyCep, vb." required />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Url" class="form-label">URL (Opsiyonel)</label>
                            <input asp-for="Url" class="form-control" placeholder="https://..." />
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Listings" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-1"></i>İptal
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check me-1"></i>Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

