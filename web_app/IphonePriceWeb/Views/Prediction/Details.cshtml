@model IphonePriceWeb.Models.PredictionHistoryItem
@{
    ViewData["Title"] = ViewData["Title"] ?? "Tahmin Detayı";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Ana Sayfa</a></li>
            <li class="breadcrumb-item"><a asp-action="History">Tahmin Geçmişi</a></li>
            <li class="breadcrumb-item active">Tahmin #@ViewData["PredictionId"]</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-receipt me-2"></i>Tahmin Detayı</h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h5>Cihaz Bilgileri</h5>
                            <table class="table">
                                <tr>
                                    <td>Model</td>
                                    <td><strong>@Model.ModelName</strong></td>
                                </tr>
                                <tr>
                                    <td>Hafıza</td>
                                    <td>@Model.Storage GB</td>
                                </tr>
                                <tr>
                                    <td>RAM</td>
                                    <td>@Model.Ram GB</td>
                                </tr>
                                <tr>
                                    <td>Durum</td>
                                    <td><span class="badge bg-info">@Model.Condition</span></td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <h5>Tahmin Sonucu</h5>
                            <div class="card bg-success text-white">
                                <div class="card-body text-center">
                                    <h2>₺@Model.PredictedPrice.ToString("N0")</h2>
                                    <p class="mb-0">~$@Model.PriceUsd.ToString("N0")</p>
                                </div>
                            </div>
                            <div class="mt-3">
                                <small class="text-muted">
                                    <i class="bi bi-graph-up me-1"></i>Güven: %@Model.Confidence<br />
                                    <i class="bi bi-calendar me-1"></i>@Model.PredictedAt.ToString("dd.MM.yyyy HH:mm")
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <a asp-action="History" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Geri
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-1"></i>Yeni Tahmin
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <!-- PartialView: Tahmin istatistikleri -->
            <partial name="_PredictionInfoPartial" />
        </div>
    </div>
</div>

