@model IEnumerable<IphonePriceWeb.Models.PredictionHistoryItem>
@{
    ViewData["Title"] = "Tahmin Geçmişi";
}

<div class="container mt-4">
    <h2><i class="bi bi-clock-history me-2"></i>Tahmin Geçmişim</h2>
    <p class="text-muted">Geçmiş fiyat tahminleriniz</p>
    
    <hr />

    <div class="card shadow">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Model</th>
                        <th>Hafıza</th>
                        <th>Durum</th>
                        <th>Tahmin Fiyatı</th>
                        <th>Tarih</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td><strong>@item.ModelName</strong></td>
                                <td>@item.Storage GB</td>
                                <td>
                                    <span class="badge bg-info">@item.Condition</span>
                                </td>
                                <td class="text-success fw-bold">₺@item.PredictedPrice.ToString("N0")</td>
                                <td>@item.PredictedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                <p class="mt-2">Henüz tahmin yapmadınız.</p>
                                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                                    İlk Tahmini Yap
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

